# ============================================================
#  AI provider selection. Switch from "mock" to real provider
#  once you have the tokens — no UI/code changes required.
# ============================================================

# LLM provider for analysis / ideas / prompt-engineering / scoring
# values: mock | yandex | qwen | glen
# AI_TEXT_PROVIDER is preferred; AI_LLM_PROVIDER still works for compatibility.
AI_TEXT_PROVIDER=mock

# Image provider for text-to-image / image-to-image
# values: mock | fal | openai
# The "Инфографика" section generates a CLEAN visual base with the image model
# and overlays the text (title, benefits) with a real font on canvas. Set this
# to "fal" (+ FAL_KEY below) for real AI bases; mock returns a placeholder base.
AI_IMAGE_PROVIDER=mock

# Override the image provider ONLY for the "Инфографика" section (the generator
# keeps using AI_IMAGE_PROVIDER). Use gpt-image as an integrated-base generator
# while Flux stays everywhere else. Leave unset to use AI_IMAGE_PROVIDER.
# values: mock | fal | fal-gpt-image | openai
# AI_INFOGRAPHIC_IMAGE_PROVIDER=fal-gpt-image

# ---- gpt-image-2 via fal.ai (recommended: reuses FAL_KEY, no OpenAI key) ----
# Uses the existing FAL_KEY above. Models default to the fal gpt-image-2 ids.
FAL_GPT_IMAGE_T2I_MODEL=openai/gpt-image-2
FAL_GPT_IMAGE_I2I_MODEL=openai/gpt-image-2/edit
# quality: low | medium | high  (higher = better card, more $)
FAL_GPT_IMAGE_QUALITY=high

# ---- OpenAI gpt-image direct (Images API) — alternative, needs an OpenAI key ----
# Optional: also acts as BYOK for fal-gpt-image if set.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Yandex Cloud (Qwen 3.6 35B, OpenAI-compatible) — recommended ----
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1g2kv9g5q3fstk360sa
YANDEX_LLM_MODEL=qwen3.6-35b-a3b
# YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1

# ---- Qwen via Alibaba DashScope (alternative LLM) ----
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-max

# ---- GLEN (LLM) — scaffold, fill in when the real API is known ----
# GLEN_API_KEY=
# GLEN_BASE_URL=
# GLEN_MODEL=glen-default

# ---- fal.ai ----
# key format: key_id:key_secret (FAL_API_KEY is also accepted)
FAL_KEY=
FAL_I2I_MODEL=fal-ai/flux-pro/kontext
FAL_T2I_MODEL=fal-ai/flux/dev
FAL_ASPECT_RATIO=3:4

# ---- Access gate ----
# Single shared password protecting the whole site (no accounts, no personal
# data). If unset, the gate is disabled (everything is public).
ACCESS_PASSWORD=
